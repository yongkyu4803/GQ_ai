<!-- 주요 주제 영역 -->
<div class="content-card mb-5">
    <h4><i class="fas fa-lightbulb me-2"></i>주요 주제</h4>
    <button type="button" class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#presentationModal">
        <i class="fas fa-tv me-2"></i>프레젠테이션 모드
    </button>
    <ul class="list-group list-group-flush mt-3">
        <% lectures.find(l => l.link === '/lecture01').mainTopics.forEach(topic => { %>
            <li class="list-group-item">
                <i class="fas fa-check-circle me-2 text-secondary"></i>
                <%= topic.title %>
                <% if (topic.subTopics && topic.subTopics.length > 0) { %>
                    <ul class="list-unstyled mt-2 ms-4">
                        <% topic.subTopics.forEach(subTopic => { %>
                            <li><small class="text-muted">• <%= subTopic %></small></li>
                        <% }); %>
                    </ul>
                <% } %>
            </li>
        <% }); %>
    </ul>
</div>

<!-- 프레젠테이션 모달 -->
<div class="modal fade" id="presentationModal" tabindex="-1" aria-labelledby="presentationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="presentationModalLabel">
                    <i class="fas fa-graduation-cap me-2"></i>디지털 리터러시와 생성형 AI
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-dark text-white p-0">
                <div class="presentation-container">
                    <!-- 슬라이드 컨트롤 -->
                    <div class="presentation-controls">
                        <button class="btn btn-outline-light me-2" onclick="prevSlide()">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <span id="slideCounter" class="text-white mx-3">1 / 6</span>
                        <button class="btn btn-outline-light ms-2" onclick="nextSlide()">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>

                    <!-- 슬라이드 컨텐츠 -->
                    <div class="slides">
                        <!-- 타이틀 슬라이드 -->
                        <div class="slide" data-slide="1">
                            <div class="slide-content">
                                <h1>디지털 리터러시와 생성형 AI</h1>
                                <h3>인공지능의 기초와 발전 과정</h3>
                            </div>
                        </div>

                        <!-- 생성형 AI의 이해 -->
                        <div class="slide" data-slide="2">
                            <div class="slide-content">
                                <h2>생성형 AI의 이해</h2>
                                <ul>
                                    <li>머신러닝과 딥러닝의 발전 과정</li>
                                    <li>GPT 모델의 진화와 특징</li>
                                    <li>생성형 AI의 현재와 미래</li>
                                </ul>
                            </div>
                        </div>

                        <!-- AI 서비스 현황 -->
                        <div class="slide" data-slide="3">
                            <div class="slide-content">
                                <h2>AI 서비스 현황</h2>
                                <ul>
                                    <li>주요 AI 서비스 비교</li>
                                    <li>분야별 AI 활용 사례</li>
                                    <li>AI 서비스 선택 시 고려사항</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.presentation-container {
    height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
}

.presentation-controls {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    padding: 10px;
    background: rgba(0, 0, 0, 0.5);
    border-radius: 20px;
}

.slides {
    flex: 1;
}

.slide {
    display: none;
    height: 100%;
    padding: 40px;
}

.slide.active {
    display: flex;
    justify-content: center;
    align-items: center;
}

.slide-content {
    text-align: center;
    max-width: 800px;
}

.slide-content h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    color: #fff;
}

.slide-content h2 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: #fff;
}

.slide-content h3 {
    font-size: 1.8rem;
    color: #aaa;
}

.slide-content ul {
    list-style: none;
    padding: 0;
    font-size: 1.5rem;
    text-align: left;
}

.slide-content ul li {
    margin: 1rem 0;
    padding-left: 2rem;
    position: relative;
}

.slide-content ul li:before {
    content: "•";
    position: absolute;
    left: 0;
    color: #667eea;
}
</style>

<script>
let currentSlide = 1;
const totalSlides = 3;

function showSlide(n) {
    const slides = document.querySelectorAll('.slide');
    slides.forEach(slide => slide.classList.remove('active'));
    
    currentSlide = n;
    if (currentSlide > totalSlides) currentSlide = 1;
    if (currentSlide < 1) currentSlide = totalSlides;
    
    document.querySelector(`[data-slide="${currentSlide}"]`).classList.add('active');
    document.getElementById('slideCounter').textContent = `${currentSlide} / ${totalSlides}`;
}

function nextSlide() {
    showSlide(currentSlide + 1);
}

function prevSlide() {
    showSlide(currentSlide - 1);
}

// 모달이 열릴 때 첫 번째 슬라이드 표시
document.getElementById('presentationModal').addEventListener('shown.bs.modal', function () {
    showSlide(1);
});

// 키보드 이벤트 처리
document.addEventListener('keydown', function(e) {
    if (document.getElementById('presentationModal').classList.contains('show')) {
        if (e.key === 'ArrowRight' || e.key === ' ') {
            nextSlide();
        } else if (e.key === 'ArrowLeft') {
            prevSlide();
        }
    }
});
</script> 