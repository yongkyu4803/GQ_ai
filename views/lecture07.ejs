    <h4><i class="fas fa-lightbulb me-2"></i>주요 주제</h4>
    <ul class="list-group list-group-flush mt-3">
        <% lectures.find(l => l.link === '/lecture07').mainTopics.forEach(topic => { %>
            <li class="list-group-item">
                <i class="fas fa-check-circle me-2 text-secondary"></i>
                <%= topic.title %>
                <% if (topic.subTopics && topic.subTopics.length > 0) { %>
                    <ul class="list-unstyled mt-2 ms-4">
                        <% topic.subTopics.forEach(subTopic => { %>
                            <li><small class="text-muted">• <%= subTopic %></small></li>
                        <% }); %>
                    </ul>
                <% } %>
            </li>
        <% }); %>
    </ul>
    <div class="text-end">
        <button type="button" class="btn btn-outline-primary btn-sm" 
                data-lecture='<%- JSON.stringify(lectures.find(l => l.link === "/lecture07")) %>'
                onclick="initializePresentation(this.dataset.lecture)"
                data-bs-toggle="modal" data-bs-target="#presentationModal">
            <i class="fas fa-tv me-2"></i>슬라이드 보기
        </button>
    </div>
</div>

