<!-- index.ejs -->
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>생성형 AI 이해하기</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Nanum+Gothic:wght@400;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.8/dist/web/static/pretendard.css" />
    <link rel="stylesheet" href="/css/navbar.css">
    <style>
        /* 인덱스 페이지 원래 스타일 */
        #landing {
            background-image: url('images/main_ai.jpg');
            background-size: 50%;
            background-position: center;
            height: 50vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            background-color: rgba(0, 0, 0, 0.4);
            background-blend-mode: overlay;
        }

        #landing h1 {
            font-size: 4rem;
            margin-bottom: 1rem;
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
            color: #e6d26a;
        }

        #landing p {
            font-size: 1.5rem;
            font-weight: 500;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
        }

        .card {
            border: none;
            border-radius: var(--border-radius);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            background: linear-gradient(135deg, #e0eafc, #cfdef3);
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.15);
        }

        .card-title {
            font-family: 'Noto Sans KR', sans-serif;
            font-weight: 700;
            color: var(--primary-color);
            font-size: 1.5rem;
        }

        .card-text {
            font-family: 'Noto Sans KR', sans-serif;
            font-weight: 400;
            color: var(--text-dark);
            font-size: 1rem;
            line-height: 1.6;
        }

        .card .btn-primary {
            font-family: 'Noto Sans KR', sans-serif;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <%- include('navbar') %>

    <!-- 랜딩 섹션 -->
    <section id="landing">         
        <div class="container text-center">             
            <h1 class="display-4 mb-4">Welcome to the Generative AI Lecture</h1>                 
            <p class="lead mb-4">Explore how Generative AI can transform your work and solve critical challenges.</p>                 
        </div>     
    </section>

    <!-- 강의 섹션 -->
    <section id="lectures" class="py-5">         
        <div class="container">             
            <div class="row">                 
                <% lectures.forEach(function(lecture) { %>
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card">
                            <div class="card-body">
                                <h2 class="card-title mb-4"><%= lecture.title %></h2>
                                <p class="card-text"><%= lecture.description %></p>
                                <a class="btn btn-outline-primary btn-sm rounded-pill" href="<%= lecture.link %>">바로가기</a>
                            </div>
                        </div>
                    </div>
                <% }); %>

                <!-- Q&A 카드 -->
                <div class="col-md-6 col-lg-4 mb-4">                     
                    <div class="card">                         
                        <div class="card-body">                             
                            <h2 class="card-title mb-4">Q&amp;A</h2>
                            <p class="card-text">질문을 통해 이해도를 높이세요.</p>
                            <a class="btn btn-outline-primary btn-sm rounded-pill" href="/qna">바로가기</a>                         
                        </div>                     
                    </div>                 
                </div>             
            </div>         
        </div>     
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
